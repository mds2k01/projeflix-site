set("log.level",3) set("server.telnet",false) set("scheduler.fast_queues",true) set("scheduler.generic_queues",true) set("decoder.max_active",3) set("decoder.file.buffer",20.) set("decoder.file.buffer_duration",20.) set("frame.audio.size",2048) set("audio.converter.samplerate.converters",["ffmpeg"]) icecast_host="localhost" icecast_port=8000 icecast_password="bqm100606" def radio(name,playlist_file) s = playlist( playlist_file, mode="normal", reload_mode="watch" ) s = mksafe(s) s = fallback([s,blank(duration=0.1)]) output.icecast( %mp3(bitrate=96,samplerate=22050,stereo=true), host=icecast_host, port=icecast_port, password=icecast_password, mount="/" ^ name, name=name ^ " Radio Projeflix", fallible=true, s ) end # Função para radios externas AAC def radio_aac(name, url) s = input.http(url) s = mksafe(s) s = fallback([s, blank(duration=0.1)]) output.icecast( %mp3(bitrate=96, samplerate=44100, stereo=true), host=icecast_host, port=icecast_port, password=icecast_password, mount="/" ^ name, name=name ^ " Radio Projeflix", fallible=true, s ) end # Radios AAC #radio_aac("sertanejo", "http://s17.maxcast.com.br:8669/live") #radio_aac("modaosertanejo", "http://stream03.dghost.com.br:8290/stream") #radio_aac("evangelizarfm", "http://8239.brasilstream.com.br/stream") radio("all","/home/mds2k01/radio-lists-liquidsoap/all.txt") radio("ambient","/home/mds2k01/radio-lists-liquidsoap/ambient.txt") radio("classic","/home/mds2k01/radio-lists-liquidsoap/classic.txt") radio("piano","/home/mds2k01/radio-lists-liquidsoap/piano.txt") radio("pop","/home/mds2k01/radio-lists-liquidsoap/pop.txt") radio("rock","/home/mds2k01/radio-lists-liquidsoap/rock.txt") radio("shorts","/home/mds2k01/radio-lists-liquidsoap/shorts.txt")